{
  "manifest_version": 3,
  "name": "WhatsApp Scam Detector",
  "version": "1.0",
  "description": "Automatically detects scam messages on WhatsApp Web using AI.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://localhost:5000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
